{
    "$schema": "https://json.schemastore.org/nest-cli",
    "collection": "@nestjs/schematics",
    "monorepo": true,
    "projects": {
        "telegram-bot": {
            "type": "application",
            "root": "apps/telegram-bot",
            "entryFile": "main",
            "sourceRoot": "apps/telegram-bot/src"
        }
    },
    "compilerOptions": {
        "tsConfigPath": "./tsconfig.build.json",
        "deleteOutDir": true
    }
}
